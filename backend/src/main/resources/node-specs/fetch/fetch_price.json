{
  "nodeType": "fetch_price",
  "set": "fetch",
  "displayName": "Fetch Price Data",
  "description": "Fetches a price-data field for a configured ticker and date.",
  "theme": "market",
  "inputs": [],
  "outputs": [
    {
      "index": 0,
      "name": "value",
      "arity": "ONE",
      "valueType": "NumVal"
    }
  ],
  "dataFields": [
    {
      "name": "ticker",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "SPY"
    },
    {
      "name": "field",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "close",
      "options": [
        "open",
        "high",
        "low",
        "close",
        "adj_close",
        "volume",
        "dividend",
        "shares_outstanding"
      ],
      "readableOptions": [
        "Open",
        "High",
        "Low",
        "Close",
        "Adjusted Close",
        "Volume",
        "Dividend",
        "Shares Outstanding"
      ]
    },
    {
      "name": "date",
      "valueType": "StrVal",
      "required": true,
      "defaultValue": "2020-04-27"
    }
  ],
  "executorKey": "fetch_price"
}
