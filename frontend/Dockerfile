# build stage
FROM node:22-alpine AS builder
WORKDIR /app

ARG VITE_API_URL
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY
ARG VITE_UMAMI_ANALYTICS_SCRIPT_URI
ARG VITE_UMAMI_ANALYTICS_WEBSITE_ID
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ENV VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY
ENV VITE_UMAMI_ANALYTICS_SCRIPT_URI=$VITE_UMAMI_ANALYTICS_SCRIPT_URI
ENV VITE_UMAMI_ANALYTICS_WEBSITE_ID=$VITE_UMAMI_ANALYTICS_WEBSITE_ID

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# runtime stage
FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
